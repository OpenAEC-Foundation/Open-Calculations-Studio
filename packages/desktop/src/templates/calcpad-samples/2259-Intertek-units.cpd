#show
#if uc тЙд 1
	'Foundation plate: 'uc = F_total,4/p_max'<span style="color:green">тЙд1.0тЖТ<b>Ok</b></span>'
#else
	'Foundation plate: 'uc = F_total,4/p_max'<span style="color:red">>1.0тЖТ<b>N.G</b></span>'
#end if
#hide
uc_4 = max(p_ground/p_soil; F_total,4/p_max)
b_fdn,4 = b_fdn
l_fdn,4 = l_fdn
#show


#if Or(uc_1 > 1.0; uc_2 > 1.0; uc_3 > 1.0; uc_4 > 1.0)
	'<h6>Total Failors</h6>
#end if
#if uc_1 > 1.0
	'<div style="color: red;"><b>Corner foundations fail to meet design criteria!</b></div>
#end if
#if uc_2 > 1.0
	'<div style="color: red;"><b>Top and bottom edge foundations fail to meet design criteria!</b></div>
#end if
#if uc_3 > 1.0
	'<div style="color: red;"><b>Left and right edge foundations fail to meet design criteria!</b></div>
#end if
#if uc_4 > 1.0
	'<div style="color: red;"><b>Middle foundations fail to meet design criteria!</b></div>
#end if

'<h4>5.4. Foundation Layout</h4> 

drawFDN$(b; l; n_Length; n_Int,support,points; b_fdn,1; b_fdn,2; b_fdn,3; b_fdn,4; l_fdn,1; l_fdn,2; l_fdn,3; l_fdn,4)

