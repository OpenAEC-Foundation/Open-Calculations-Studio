BuildingHeight_x1 = take(1; hlookup_ge(M; h_Building; 1; 1))
BuildingHeight_x2 = take(n_rows(hlookup_le(M; h_Building; 1; 1)); hlookup_le(M; h_Building; 1; 1))

#if BuildingHeight_x1 тЙб BuildingHeight_x2
	y = hlookup(M; BuildingHeight_x1; 1; (WindTerrain + 1))
