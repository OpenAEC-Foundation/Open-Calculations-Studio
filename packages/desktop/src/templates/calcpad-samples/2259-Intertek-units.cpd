	#if and(p_ground/p_soil тЙд 1.0; F_total,4/p_max тЙд 1.0)
		#break
	#end if
#loop
#show
'Type: 'f_Middle

A = b_fdn*l_fdn
F_total,4 = 2*F_total,3
F_total_u = F_total,4 + G_fdn*1.2
p_ground = F_total_u/A|kN/m^2', Ground pressure'

'<h6>Unity Check</h6>
#hide
uc = p_ground/p_soil
#show
#if uc тЙд 1
	'Ground pressure: 'uc = p_ground/p_soil'<span style="color:green">тЙд1.0тЖТ<b>Ok</b></span>'
