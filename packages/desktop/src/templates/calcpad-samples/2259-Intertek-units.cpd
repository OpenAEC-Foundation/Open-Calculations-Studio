	y_1 = hlookup(M; BuildingHeight_x1; 1; (WindTerrain + 1))
	y_2 = hlookup(M; BuildingHeight_x2; 1; (WindTerrain + 1))
	y = y_1 + (h_Building - BuildingHeight_x1)/(BuildingHeight_x2 - BuildingHeight_x1)*(y_2 - y_1)
#end if

