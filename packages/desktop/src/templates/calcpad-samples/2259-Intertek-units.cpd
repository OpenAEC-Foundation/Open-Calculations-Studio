'<h2>5. Calculations</h2>
'<h3>5.1 Load take down</h3>
drawFloor$(l;b;(n_Int,support,points + 1))
drawCeiling$(l;b)
drawSide$(l;h;n_story)

l', 'b', 'h
'<h6>5.1.1. Calculation of effective length</h6>
b_1 = b/2
L_A = l/(2*(n_Int,support,points + 1))
L_B = 2*L_A
L_C = l/2
'<h6>5.1.2. Calculation of effective area</h6>
A_A = b_1*L_A' for floor
A_B = b_1*L_B' for floor
A_C = b_1*L_C' for roof
'<h3>5.2. Stability calculation in the wind</h3>
q_p

'<table class="">
'<thead>
'<tr><th style="width:30%">c</th><th>P<sub>rep</sub></th></tr>
'</thead>
'<tbody>
'<tr><td>'c_1 = 0.02'</td><td>тЖТ'P_rep,1 = q_p*c_1'</td></tr>
'<tr><td>'c_2 = 0.50'</td><td>тЖТ'P_rep,2 = q_p*c_2'</td></tr>
'<tr><td>'c_3 = 0.80'</td><td>тЖТ'P_rep,3 = q_p*c_3'</td></tr>
'<tr><td>'c_4 = 1.10'</td><td>тЖТ'P_rep,4 = q_p*c_4'</td></tr>
'</tbody>
'</table>

#noc
╧И_0,wind = 0.0:F2
╧И_1,wind = 0.2:F2
╧И_2,wind = 0.0:F2
#equ

'The modules are connected as a single unit.
'The connections can transfer shear, tension, and compression forces in three directions

drawWind$(b; l; n_Length)
'<h4>5.2.1. Wind 1</h4>
L_total = n_Length*b
B_total = l
H_total = n_story*h
G_unit,total = n_story*n_Length*G_unit

'<h6>Area calculation</h6>
A_WindPressure,Suction = B_total*H_total
A_RoofFriction = L_total*B_total
A_FacadeFriction = L_total*H_total*2

'<h6>Force calculation</h6>
F_WindSuction = A_WindPressure,Suction*P_rep,2
F_WindPressure = A_WindPressure,Suction*P_rep,3
F_RoofFriction = A_RoofFriction*P_rep,1
F_Friction = A_FacadeFriction*P_rep,1
F_Wind,total = F_WindSuction + F_WindPressure + F_RoofFriction + F_Friction

'<h6>Calculation of safety factor</h6>
h_WindResultant = H_total/2
F_wind,ED = F_Wind,total*╬│_Q,610b
M_wind = F_wind,ED*h_WindResultant
F_0.9G50%TotalWeight = G_unit,total*0.9*0.5
e_FoundationLeg = L_total
F_wind,zijde = M_wind/e_FoundationLeg
#hide
uc_trek = F_wind,zijde/F_0.9G50%TotalWeight
#show

#if uc_trek тЙд 1
	uc_trek = F_wind,zijde/F_0.9G50%TotalWeight'<span style="color: green">тЙд 1.0 тЖТ Ok</span>
#else
	uc_trek = F_wind,zijde/F_0.9G50%TotalWeight'<span style="color: red">> 1.0 тЖТ N.G</span>
#end if

'<h4>5.2.2. Wind 2</h4>
L_total = n_Width*b
B_total = l
H_total = n_story*h
G_unit,total = n_story*n_Width*G_unit

'<h6>Area calculation</h6>
A_WindPressure,Suction = L_total*H_total
A_RoofFriction = B_total*L_total
A_FacadeFriction = B_total*H_total*2

'<h6>Force calculation</h6>
F_WindSuction = A_WindPressure,Suction*P_rep,2
F_WindPressure = A_WindPressure,Suction*P_rep,3
F_RoofFriction = A_RoofFriction*P_rep,1
F_Friction = A_FacadeFriction*P_rep,1
F_Wind,total = F_WindSuction + F_WindPressure + F_RoofFriction + F_Friction

'<h6>Calculation of safety factor</h6>
h_WindResultant = H_total/2
F_wind,ED = F_Wind,total*╬│_Q,610b
M_wind = F_wind,ED*h_WindResultant
F_0.9G50%TotalWeight = G_unit,total*0.9*0.5
e_FoundationLeg = B_total
F_wind,zijde = M_wind/e_FoundationLeg
#hide
uc_trek = F_wind,zijde/F_0.9G50%TotalWeight
#show

#if uc_trek тЙд 1
	uc_trek = F_wind,zijde/F_0.9G50%TotalWeight'<span style="color: green">тЙд 1.0 тЖТ Ok</span>
#else
	uc_trek = F_wind,zijde/F_0.9G50%TotalWeight'<span style="color: red">> 1.0 тЖТ N.G</span>
#end if

'<h3>5.3 Foundation</h3>
#def getFdn$(ii$)
	#hide
	#if ii$ тЙб 1
		'тЖТ'b_fdn = 0.58m
		'тЖТ'l_fdn = 0.4m
		'тЖТ't_fdn = 0.05m'тЖТ'G_fdn = 11kN
		'тЖТ'p_max = 120kN
	#else if ii$ тЙб 2
		'тЖТ'b_fdn = 0.5m
		'тЖТ'l_fdn = 0.5m
		'тЖТ't_fdn = 0.05m
		'тЖТ'G_fdn = 11.5kN
		'тЖТ'p_max = 120kN
	#else if ii$ тЙб 3
		'тЖТ'b_fdn = 0.8m
		'тЖТ'l_fdn = 0.8m
		'тЖТ't_fdn = 0.045m
		'тЖТ'G_fdn = 2.8kN
		'тЖТ'p_max = 200kN
	#else if ii$ тЙб 4
		'тЖТ'b_fdn = 1.0m
		'тЖТ'l_fdn = 1.0m
		'тЖТ't_fdn = 0.14m
		'тЖТ'G_fdn = 3.5kN
		'тЖТ'p_max = 150kN
	#else if ii$ тЙб 5
		'тЖТ'b_fdn = 1.0m
		'тЖТ'l_fdn = 2.0m
		'тЖТ't_fdn = 0.14m
		'тЖТ'G_fdn = 7.0kN
		'тЖТ'p_max = 150kN
	#else if ii$ тЙб 6
		'тЖТ'b_fdn = 1.0m
		'тЖТ'l_fdn = 2.0m
		'тЖТ't_fdn = 0.16m
		'тЖТ'G_fdn = 8.0kN
		'тЖТ'p_max = 200kN
	#else if ii$ тЙб 7
		'тЖТ'b_fdn = 2.0m
		'тЖТ'l_fdn = 2.0m
		'тЖТ't_fdn = 0.14m
		'тЖТ'G_fdn = 14.0kN
		'тЖТ'p_max = 150kN
	#else if ii$ тЙб 8
		'тЖТ'b_fdn = 2.0m
		'тЖТ'l_fdn = 2.0m
		'тЖТ't_fdn = 0.16m
		'тЖТ'G_fdn = 16.0kN
		'тЖТ'p_max = 200kN
	#else if ii$ тЙб 9
		'тЖТ'b_fdn = 2.0m
		'тЖТ'l_fdn = 2.0m
		'тЖТ't_fdn = 0.25m
		'тЖТ'G_fdn = 25.0kN
		'тЖТ'p_max = 420kN
	#end if
	#show
#end def
'<h5>5.3.1 Corner (1)</h5>
'<h6>Dead Loads (G)</h6>
F_Other_weight = 1m^2*p_other
F_Roof = n_story*A_C*P_D,roof
#if n_story тЙб 1
	F_Floor = A_A*P_D,floor
#else
	F_Floor = (n_story - 1)*A_C*P_D,floor + A_A*P_D,floor
#end if
F_Dead = F_Other_weight + F_Roof + F_Floor

'<h6>Live Loads (Q)</h6>
F_Roof = A_C*P_L,FlatRoof
#if n_story тЙб 1
	F_Floor = A_A*P_Live
#else
	F_Floor = (n_story - 1)*A_C*P_Live + A_A*P_Live
#end if
F_Live = F_Roof + F_Floor

'<h6>Total Loads</h6>
F_total_1 = ╬│_Gsup,610b*F_Dead + ╬│_Q,610b*F_Live
F_total_2 = ╬│_Gsup,610a*F_Dead + ╬│_Q,610b*F_Floor*╧И_0
F_total,1 = max(F_total_1; F_total_2)

#hide 
f_Corner = 0
#show
#for i = 1 : 9
	getFdn$(i)
	#hide
	A = b_fdn*l_fdn
	F_total_u = F_total,1 + G_fdn*1.2
	p_ground = F_total_u/A|kN/m^2', Ground pressure'
	f_Corner = i
	#if and(p_ground/p_soil тЙд 1.0; F_total,1/p_max тЙд 1.0)
		#break
	#end if
#loop
#show
'Type: 'f_Corner
A = b_fdn*l_fdn
F_total_u = F_total,1 + G_fdn*1.2
p_ground = F_total_u/A|kN/m^2', Ground pressure'

'<h6>Unity Check</h6>
#hide
uc = p_ground/p_soil
#show
#if uc тЙд 1
	'Ground pressure: 'uc = p_ground/p_soil'<span style="color:green">тЙд1.0тЖТ<b>Ok</b></span>'
#else
	'Ground pressure: 'uc = p_ground/p_soil'<span style="color:red">>1.0тЖТ<b>N.G</b></span>'
#end if
#hide
uc = F_total,1/p_max
#show
#if uc тЙд 1
	'Foundation plate: 'uc = F_total,1/p_max'<span style="color:green">тЙд1.0тЖТ<b>Ok</b></span>'
#else
	'Foundation plate: 'uc = F_total,1/p_max'<span style="color:red">>1.0тЖТ<b>N.G</b></span>'
#end if

#hide
'----------------------------------------------------------------------------------------------
uc_1 = max(p_ground/p_soil; F_total,1/p_max)
b_fdn,1 = b_fdn
l_fdn,1 = l_fdn

#show
'<h5>5.3.2. Top/Bottom Edge (2)</h5>
#hide
f_Edge1 = 0
#show
#for i = 1 : 9
	getFdn$(i)
	#hide
	A = b_fdn*l_fdn
	F_total,2 = 2*F_total,1
	F_total_u = F_total,2 + G_fdn*1.2
	p_ground = F_total_u/A|kN/m^2', Ground pressure'
	f_Edge1 = i
	#if and(p_ground/p_soil тЙд 1.0; F_total,2/p_max тЙд 1.0)
		#break
	#end if
#loop
#show
'Type: 'f_Edge1
A = b_fdn*l_fdn
F_total,2 = 2*F_total,1
F_total_u = F_total,2 + G_fdn*1.2
p_ground = F_total_u/A|kN/m^2', Ground pressure'

'<h6>Unity Check</h6>
#hide
uc = p_ground/p_soil
#show
#if uc тЙд 1
	'Ground pressure: 'uc = p_ground/p_soil'<span style="color:green">тЙд1.0тЖТ<b>Ok</b></span>'
#else
	'Ground pressure: 'uc = p_ground/p_soil'<span style="color:red">>1.0тЖТ<b>N.G</b></span>'
#end if
#hide
uc = F_total,2/p_max
#show
#if uc тЙд 1
	'Foundation plate: 'uc = F_total,2/p_max'<span style="color:green">тЙд1.0тЖТ<b>Ok</b></span>'
#else
	'Foundation plate: 'uc = F_total,2/p_max'<span style="color:red">>1.0тЖТ<b>N.G</b></span>'
#end if
#hide
uc_2 = max(p_ground/p_soil; F_total,2/p_max)
b_fdn,2 = b_fdn
l_fdn,2 = l_fdn
#show

'<h5>5.3.3. Side Edge (3)</h5>
'<h6>Dead Loads (G)</h6>
F_Other_weight = 1m^2*p_other
F_Floor = A_B*P_D,floor
F_Dead = F_Other_weight + F_Floor

'<h6>Live Loads (Q)</h6>
F_Floor = A_B*P_Live
F_Live = F_Floor

'<h6>Total Loads</h6>
F_total_1 = ╬│_Gsup,610b*F_Dead + ╬│_Q,610b*F_Live
F_total_2 = ╬│_Gsup,610a*F_Dead + ╬│_Q,610b*F_Floor*╧И_0
F_total,3 = max(F_total_1; F_total_2)

#hide
f_Edge2 = 0
#show
#for i = 1 : 6
	getFdn$(i)
	#hide
	A = b_fdn*l_fdn
	F_total_u = F_total,3 + G_fdn*1.2
	p_ground = F_total_u/A|kN/m^2', Ground pressure'
	f_Edge2 = i
	#if and(p_ground/p_soil тЙд 1.0; F_total,3/p_max тЙд 1.0)
		#break
	#end if
#loop
#show
'Type: 'f_Edge2
A = b_fdn*l_fdn
F_total_u = F_total,3 + G_fdn*1.2
p_ground = F_total_u/A|kN/m^2', Ground pressure'

'<h6>Unity Check</h6>
